                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Button fx:id="btn00" mnemonicParsing="false" onAction="#CasillaClick" prefHeight="120.0" prefWidth="120.0" text=""
