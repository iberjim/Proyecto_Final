                        <Button fx:id="btn10" mnemonicParsing="false" onAction="#CasillaClick" prefHeight="120.0" prefWidth="120.0" text="" GridPane.rowIndex="1"
                                style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-width: 1 1 1 0; -fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #333333;" />

                        <Button fx:id="btn11" mnemonicParsing="false" onAction="#CasillaClick" prefHeight="120.0" prefWidth="120.0" text="" GridPane.columnIndex="1" GridPane.rowIndex="1"
                                style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-width: 1 1 1 1; -fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #333333;" />

                        <Button fx:id="btn12" mnemonicParsing="false" onAction="#CasillaClick" prefHeight="120.0" prefWidth="120.0" text="" GridPane.columnIndex="2" GridPane.rowIndex="1"
