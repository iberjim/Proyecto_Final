                        <Button fx:id="btn21" mnemonicParsing="false" onAction="#CasillaClick" prefHeight="120.0" prefWidth="120.0" text="" GridPane.columnIndex="1" GridPane.rowIndex="2"
                                style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-width: 1 1 0 1; -fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #333333;" />

                        <Button fx:id="btn22" mnemonicParsing="false" onAction="#CasillaClick" prefHeight="120.0" prefWidth="120.0" text="" GridPane.columnIndex="2" GridPane.rowIndex="2"
                                style="-fx-background-color: transparent; -fx-border-color: #cccccc; -fx-border-width: 1 0 0 1; -fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #333333;" />
                    </children>
                </GridPane>
                <Label fx:id="lblTurno" layoutX="23.0" layoutY="148.0" text="Label" />
            <Button fx:id="btnReiniciar" layoutX="551.0" layoutY="33.0" mnemonicParsing="false" onAction="#ReiniciarClick" text="REINICIAR" />
